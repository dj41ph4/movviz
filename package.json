{
  "name": "movviz",
  "version": "1.1.61",
  "private": true,
  "description": "Movviz — centre de commande média unifié. Découvrez, demandez, indexez et gérez films et séries depuis une interface unique et cinématographique.",
  "scripts": {
    "dev": "next dev -p 9810",
    "build": "next build",
    "start": "next start -p 9810",
    "engine": "node engine/src/index.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "service:install": "node packaging/windows/service.js install",
    "service:uninstall": "node packaging/windows/service.js uninstall"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "node-windows": "^1.0.0-beta.8"
  }
}
